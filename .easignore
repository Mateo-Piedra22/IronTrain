# EAS Build Ignore File
# Prevents unnecessary files from being uploaded to EAS Build servers.
# Documentation: https://docs.expo.dev/build-reference/easignore/

# --- Inherited from .gitignore (Explicitly re-stated for clarity) ---
node_modules/
.expo/
dist/
web-build/
ios/
android/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
.env
.env.*
.env*.local
*.tsbuildinfo
npm-debug.*
yarn-debug.*
yarn-error.*
.DS_Store
*.pem

# --- AI & Tool Metadata ---
.agent/
.agents/
.claude/
.trae/
.windsurf/
.serena/
.vscode/
.github/

# --- Project-Specific Exclusions (NOT needed for mobile build) ---
# The website is a separate Next.js project and is the largest source of "bloat" in builds.
website/
docs/
_backup_web/

# Credentials & Secrets (Security)
# These should be handled via EAS Secrets, not uploaded in the context if possible.
# Note: google-services.json is ignored to ensure secrets from EAS are used.
google-services.json
GoogleService-Info.plist
app-irontrain-firebase-adminsdk-*.json
firebase-adminsdk-*.json

# Source Assets & Reference Files
Logo IronTrain.*
batch_migration_log.md
jest_out.txt
tmp/
start_dev.ps1

# Non-build scripts
# We keep scripts/patch-css-interop.js and scripts/recreate-secrets.js (used in EAS hooks)
# but skip those that are clearly for local development or website management.
scripts/sync-website-content.js
scripts/release-prepare.js
scripts/release-finalize.js
scripts/generate-sounds.js

