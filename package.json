{
  "name": "temp_init",
  "main": "expo-router/entry",
  "version": "2.1.0",
  "scripts": {
    "start": "node scripts/dev.js",
    "android": "node scripts/dev.js --android",
    "ios": "node scripts/dev.js --ios",
    "web": "node scripts/dev.js --web",
    "generate-changelog": "node scripts/generate-changelog.js",
    "audit": "node scripts/audit.js",
    "website:sync-content": "node -e \"require('./scripts/sync-website-content').syncWebsiteContent(require('path').resolve(__dirname))\"",
    "release:prepare": "node scripts/release-prepare.js",
    "release:finalize": "node scripts/release-finalize.js",
    "postinstall": "node scripts/patch-css-interop.js && node scripts/patch-keep-awake.js && node scripts/generate-changelog.js",
    "eas-build-pre-install": "node scripts/recreate-secrets.js",
    "deploy:mobile": "node scripts/deploy-mobile.js",
    "deploy:hotfix": "node scripts/deploy-hotfix.js",
    "prebuild:eas": "npm run audit && npm run generate-changelog && npm run website:sync-content",
    "pretest": "node scripts/generate-changelog.js",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/website/"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@notifee/react-native": "^9.1.8",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-keep-awake": "^15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.7",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.562.0",
    "lucide-react-native": "^0.562.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "expo-module-scripts": "^55.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
