{
  "expo": {
    "name": "IronTrain",
    "slug": "irontrain",
    "version": "2.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "irontrain",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff7f1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.irontrain.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "IronTrain usa tu ubicación aproximada al finalizar entrenamientos para detectar clima adverso y aplicar bonus opcionales de puntaje."
      }
    },
    "android": {
      "package": "com.irontrain.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fff7f1"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/SpaceMono-Regular.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a1a2e"
        }
      ],
      "expo-secure-store",
      "expo-location",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "updateFeedUrl": "https://irontrain.motiona.xyz/releases.json",
      "backendUrl": "https://irontrain.motiona.xyz",
      "eas": {
        "projectId": "76d89df6-9ab1-4903-af08-64d0bc630646"
      }
    }
  }
}
